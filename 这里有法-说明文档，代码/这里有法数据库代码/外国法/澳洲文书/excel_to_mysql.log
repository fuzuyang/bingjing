CREATE TABLE Australia (
    id INT AUTO_INCREMENT PRIMARY KEY,
    case_class varchar(50),
    case_name varchar(597),
    court varchar(200),
    jurisdiction varchar(200),
    decision_date varchar(50),
    primary_parties_plaintiff varchar(312),
    primary_parties_defendant varchar(360),
    primary_parties_prosecutor varchar(155),
    primary_parties_accused varchar(239),
    appellate_parties_appellant varchar(374),
    appellate_parties_respondent_on_appeal varchar(579),
    cause_of_action varchar(926),
    grounds_of_appeal longtext,
    final_orders_trial longtext,
    outcome_of_appeal varchar(810),
    processing_status varchar(50),
    reason varchar(951),
    judges varchar(210),
    counsel longtext,
    other_parties_if_any longtext,
    material_facts longtext,
    legislation_considered longtext,
    key_cases_cited longtext,
    appellate_parties_cross_appellant varchar(210),
    appellate_parties_interveners varchar(443),
    lower_court_history longtext,
    appellant_s_submissions longtext,
    respondent_s_submissions longtext,
    appellate_court_reasoning longtext,
    primary_parties_applicant varchar(458),
    primary_parties_respondent longtext,
    plaintiff longtext,
    defendant longtext,
    primary_judge_s_reasoning longtext,
    appellant_s_submissions_1 varchar(921),
    respondent_s_submissions_1 varchar(683),
    final_orders_trial_1 varchar(173),
    primary_judge_s_reasoning_1 longtext,
    original_text varchar(200)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
