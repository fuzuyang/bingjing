CREATE TABLE Vietnam_document (
    id INT AUTO_INCREMENT PRIMARY KEY,
    Tiêu_đề_bản_án varchar(399),
    Số_hiệu_bản_án varchar(50),
    Loại_vụ_án varchar(200),
    Cấp_xét_xử varchar(50),
    Ngày_xét_xử varchar(50),
    Tòa_án_xét_xử varchar(165),
    Nguyên_đơn longtext,
    Bị_đơn varchar(402),
    Người_kháng_cáo varchar(524),
    Người_bị_kháng_cáo longtext,
    Thẩm_phán varchar(200),
    Tình_tiết_vụ_án_facts longtext,
    Yêu_cầu_của_nguyên_đơn longtext,
    Yêu_cầu_của_bị_đơn longtext,
    Vấn_đề_pháp_lý_cần_giải_quyết_issue varchar(618),
    Lập_luận_của_Tòa_án_reasoning longtext,
    Đánh_giá_chứng_cứ longtext,
    Áp_dụng_pháp_luật longtext,
    Phán_quyết_sơ_thẩm longtext,
    Nội_dung_kháng_cáo longtext,
    Nhận_định_của_phúc_thẩm longtext,
    Quyết_định_phúc_thẩm longtext,
    Status varchar(50),
    Quyết_định_giám_đốc_thẩm varchar(717),
    Nhận_định_của_giám_đốc_thẩm varchar(380),
    Đòi_tài_sản varchar(278)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
